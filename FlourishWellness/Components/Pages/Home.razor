@page "/"
@using FlourishWellness.Services
@inject NavigationManager NavigationManager
@inject AuthStateService AuthStateService
@inject SurveyService SurveyService

<PageTitle>Home - FlourishWellness</PageTitle>

<div style="text-align: center; padding: 40px 0;">
    <h1 style="color: #196887; font-size: 48px; margin-bottom: 20px;">FlourishWellness</h1>
    <p style="font-size: 20px; color: #5f6062; margin-bottom: 40px;">
        Americare Senior Living
    </p>

    @if (AuthStateService.RequiresFacilitySelection)
    {
        <div style="max-width: 675px; margin: 0 auto 22px auto; padding: 18px; border: 2px solid #ebbc4d; border-radius: 8px; background-color: #fffaec; color: #5f6062;">
            <h4 style="margin-top: 0;">Facility selection required</h4>
            <p style="font-size: 13.5px; margin-bottom: 12px;">
                Your account is linked to multiple facilities. Choose the facility you are accessing.
            </p>
            <div style="display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;">
                <select @bind="selectedFacilityValue" style="min-width: 315px; padding: 7px; border: 1px solid #d1d3d5; border-radius: 4px; font-size: 13.5px;">
                    <option value="">-- Select facility --</option>
                    @foreach (var option in AuthStateService.ADFacilities)
                    {
                        <option value="@BuildSelectionValue(option)">@option.Facility (@(string.IsNullOrWhiteSpace(option.CommunityKey) ? "No CommunityKey" : option.CommunityKey))</option>
                    }
                </select>
                <button @onclick="SaveFacilitySelection"
                        style="padding: 7px 15px; background-color: #196887; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 13.5px;">
                    Confirm Facility
                </button>
            </div>
        </div>
    }

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-top: 50px;">
        @if (!AuthStateService.IsEmployee)
        {
            <div style="padding: 30px; border: 1px solid #d1d3d5; border-radius: 8px; background-color: #f6f9f7;">
                <h3 style="color: #269cce; margin-top: 0;">📊 Dashboard</h3>
                <p style="color: #5f6062; margin-bottom: 20px;">
                    View analytics, statistics, and insights about audit responses.
                </p>
                <a href="/dashboard" style="display: inline-block; padding: 10px 30px; background-color: #269cce; color: white; text-decoration: none; border-radius: 5px; font-weight: 500;">
                    View Dashboard
                </a>
            </div>
        }

        @if (!AuthStateService.RequiresFacilitySelection)
        {
            <div style="padding: 30px; border: 1px solid #d1d3d5; border-radius: 8px; background-color: #f6f9f7;">
                <h3 style="color: #196887; margin-top: 0;">📋 Take Audit</h3>
                <p style="color: #5f6062; margin-bottom: 20px;">
                    Complete our wellness assessment to help us understand your needs better.
                </p>
                <a href="/survey" style="display: inline-block; padding: 10px 30px; background-color: #196887; color: white; text-decoration: none; border-radius: 5px; font-weight: 500;">
                    Start Audit
                </a>
            </div>
        }

        @if (!AuthStateService.RequiresFacilitySelection && hasSubmittedAndLockedSurvey)
        {
            <div style="padding: 30px; border: 1px solid #d1d3d5; border-radius: 8px; background-color: #f6f9f7;">
                <h3 style="color: #387c2b; margin-top: 0;">🧭 Action Plans</h3>
                <p style="color: #5f6062; margin-bottom: 20px;">
                    Build and track growth areas from your submitted and locked audit.
                </p>
                <a href="/action-plans" style="display: inline-block; padding: 10px 30px; background-color: #387c2b; color: white; text-decoration: none; border-radius: 5px; font-weight: 500;">
                    Open Action Plans
                </a>
            </div>
        }

        @if (AuthStateService.IsManager || AuthStateService.IsAdmin)
        {
            <div style="padding: 30px; border: 1px solid #d1d3d5; border-radius: 8px; background-color: #f6f9f7;">
                <h3 style="color: #439539; margin-top: 0;">📑 View Results</h3>
                <p style="color: #5f6062; margin-bottom: 20px;">
                    Review all submitted audit responses organized by category.
                </p>
                <a href="/results" style="display: inline-block; padding: 10px 30px; background-color: #439539; color: white; text-decoration: none; border-radius: 5px; font-weight: 500;">
                    View Results
                </a>
            </div>
        }

        @if (AuthStateService.IsAdmin)
        {
            <div style="padding: 30px; border: 1px solid #d1d3d5; border-radius: 8px; background-color: #f6f9f7;">
                <h3 style="color: #387c2b; margin-top: 0;">⚙️ Admin Panel</h3>
                <p style="color: #5f6062; margin-bottom: 20px;">
                    Manage audit sections and questions for the assessment.
                </p>
                <a href="/admin" style="display: inline-block; padding: 10px 30px; background-color: #387c2b; color: white; text-decoration: none; border-radius: 5px; font-weight: 500;">
                    Go to Admin
                </a>
            </div>
        }
    </div>
</div>

@code {
    private string selectedFacilityValue = string.Empty;
    private bool hasSubmittedAndLockedSurvey = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthStateService.InitializeAsync();

        if (AuthStateService.SelectedFacility != null)
        {
            selectedFacilityValue = BuildSelectionValue(AuthStateService.SelectedFacility);
        }

        await LoadActionPlansAvailabilityAsync();
    }

    private static string BuildSelectionValue(FlourishWellness.Models.ADFacilityUser facility)
    {
        return $"{facility.Facility}|{facility.CommunityKey}";
    }

    private async Task SaveFacilitySelection()
    {
        if (string.IsNullOrWhiteSpace(selectedFacilityValue))
        {
            return;
        }

        var split = selectedFacilityValue.Split('|', 2);
        var facility = split[0];
        var communityKey = split.Length > 1 ? split[1] : null;
        await AuthStateService.SetSelectedFacilityAsync(facility, communityKey);
        await LoadActionPlansAvailabilityAsync();
    }

    private async Task LoadActionPlansAvailabilityAsync()
    {
        hasSubmittedAndLockedSurvey = false;

        if (AuthStateService.CurrentUser == null || AuthStateService.RequiresFacilitySelection)
        {
            return;
        }

        var communityKey = GetSelectedCommunityKey();
        if (communityKey <= 0)
        {
            return;
        }

        hasSubmittedAndLockedSurvey = await SurveyService.IsSurveyCompletedAsync(AuthStateService.CurrentUser.Id, communityKey);
    }

    private int? GetSelectedCommunityKey()
    {
        var ck = AuthStateService.SelectedFacility?.CommunityKey;
        return int.TryParse(ck, out var val) ? val : 0;
    }
}