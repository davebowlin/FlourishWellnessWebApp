@using FlourishWellness.Models
@using FlourishWellness.Services
@using System.Text

@page "/results"
@inject SurveyService SurveyService
@inject AuthStateService AuthStateService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject LogService LogService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Audit Results</PageTitle>

<h3>Audit Results</h3>

@if (sections is null)
{
    <p><em>Loading results...</em></p>
}
else if (!sections.Any())
{
    <p><em>No audit data available yet.</em></p>
}
else if (!HasAnyResponses(sections))
{
    <p><em>No completed audit responses are available yet.</em></p>
}
else
{
    <div style="margin-bottom: 20px; display: flex; gap: 10px;">
        <button @onclick="LoadResults"
                style="padding: 10px 30px; background-color: #439539; color: white; border: none; border-radius: 5px; font-size: 16px; cursor: pointer;">
            Refresh Results
        </button>
        <button @onclick="ExportToCSV"
                style="padding: 10px 30px; background-color: #269cce; color: white; border: none; border-radius: 5px; font-size: 16px; cursor: pointer;">
            Export to CSV
        </button>
    </div>

    @foreach (var group in groupedSummaries)
    {
        var isExpanded = expandedTopSections.Contains(group.TopSectionName);
        <div class="fw-accordion-panel">
            <div class="fw-accordion-header" @onclick="@(() => ToggleTopSection(group.TopSectionName))">
                <h4 class="fw-accordion-title">
                    <span class="fw-accordion-chevron">@(isExpanded ? "▼" : "▶")</span>
                    @group.TopSectionName
                </h4>
                <span class="fw-accordion-meta">@group.QuestionSummaries.Count question summary item(s)</span>
            </div>

            @if (isExpanded)
            {
                <div class="fw-accordion-body">
                    @foreach (var summary in group.QuestionSummaries)
                    {
                        <div style="margin: 12px 0; padding: 16px; border: 1px solid #d1d3d5; border-radius: 8px; background-color: white;">
                            <h5 style="margin: 0 0 6px 0; color: #196887;">@summary.SectionPath</h5>
                            <div style="margin: 0 0 10px 0; color: #5f6062; font-weight: 600;">@summary.QuestionText</div>
                            <p style="margin: 0 0 14px 0; color: #5f6062;"><strong>@summary.TotalResponses</strong> completed response(s)</p>

                            <div style="margin-bottom: 12px;">
                                <div style="height: 26px; background-color: #e9eeea; border-radius: 999px; overflow: hidden; display: flex;">
                                    @foreach (var option in AnswerOptions)
                                    {
                                        var count = summary.Counts.GetValueOrDefault(option.Label, 0);
                                        var percentage = summary.Percentages.GetValueOrDefault(option.Label, 0d);
                                        var label = $"{percentage:0.#}%";
                                        <div title="@($"{option.Label}: {count} ({percentage:0.0}%)")"
                                             style="height: 100%; width: @FormatPercentForWidth(percentage); background-color: @option.Color; display: flex; align-items: center; justify-content: center; color: #1f1f1f; font-size: 12px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: clip;">
                                            @if (percentage >= 12d)
                                            {
                                                @label
                                            }
                                    </div>
                                    }
                                </div>
                                <div style="display: flex; flex-wrap: wrap; gap: 14px; margin-top: 8px; color: #5f6062; font-size: 13px;">
                                    @foreach (var option in AnswerOptions)
                                    {
                                        var count = summary.Counts.GetValueOrDefault(option.Label, 0);
                                        var percentage = summary.Percentages.GetValueOrDefault(option.Label, 0d);
                                        <span style="display: inline-flex; align-items: center; gap: 6px;">
                                            <span style="display: inline-block; width: 11px; height: 11px; border-radius: 50%; background-color: @option.Color;"></span>
                                            @option.Label (@count, @percentage.ToString("0.0")%)
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<Section>? sections;
    private List<QuestionSummaryRow> questionSummaries = new();
    private List<TopSectionSummaryGroup> groupedSummaries = new();
    private HashSet<string> expandedTopSections = new(StringComparer.OrdinalIgnoreCase);

    private static readonly List<AnswerOptionColor> AnswerOptions = new()
    {
        new("Fully Implemented", "#439539"),
        new("Partially Implemented", "#269cce"),
        new("Not a Current Practice", "#ebbc4d")
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthStateService.InitializeAsync();
            await AuthStateService.RefreshCurrentUserAsync();

            if (!(AuthStateService.IsAdmin || AuthStateService.IsManager))
            {
                await LogService.LogAsync("Unauthorized results page access attempt", AuthStateService.CurrentUser?.Email ?? "Unknown");
                NavigationManager.NavigateTo("/");
                return;
            }

            await LoadResults();
        }
        catch (Exception ex)
        {
            await LogService.LogAsync($"Error in Results OnInitializedAsync: {ex.Message}", "System");
            Console.WriteLine($"Results page error: {ex}");
            sections = new List<Section>();
        }
    }

    private async Task LoadResults()
    {
        try
        {
            sections = await SurveyService.GetSectionsWithCompletedResponsesAsync();
            if (sections == null)
            {
                sections = new List<Section>();
            }
            questionSummaries = BuildQuestionSummaries(sections);
            groupedSummaries = BuildTopSectionGroups(questionSummaries);
            expandedTopSections = groupedSummaries
                .Select(g => g.TopSectionName)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            await LogService.LogAsync($"Error loading results: {ex.Message}", "System");
            sections = new List<Section>();
            questionSummaries = new List<QuestionSummaryRow>();
            groupedSummaries = new List<TopSectionSummaryGroup>();
            expandedTopSections.Clear();
        }
    }

    private void ToggleTopSection(string topSectionName)
    {
        if (!expandedTopSections.Add(topSectionName))
        {
            expandedTopSections.Remove(topSectionName);
        }
    }

    private bool HasAnyResponses(List<Section> secs)
    {
        foreach (var sec in secs)
        {
            if (sec.Questions.Any(q => q.Responses.Any()))
                return true;
            if (sec.Subsections.Any() && HasAnyResponses(sec.Subsections))
                return true;
        }
        return false;
    }

    private static List<QuestionSummaryRow> BuildQuestionSummaries(List<Section> roots)
    {
        var summaries = new List<QuestionSummaryRow>();

        void Traverse(Section section, string parentPath, string topSectionName)
        {
            var sectionPath = string.IsNullOrWhiteSpace(parentPath)
                ? section.Name
                : $"{parentPath} > {section.Name}";

            foreach (var question in section.Questions)
            {
                var total = question.Responses.Count;
                if (total == 0)
                {
                    continue;
                }

                var counts = AnswerOptions.ToDictionary(a => a.Label, _ => 0, StringComparer.OrdinalIgnoreCase);
                foreach (var response in question.Responses)
                {
                    if (counts.ContainsKey(response.Answer))
                    {
                        counts[response.Answer]++;
                    }
                }

                var percentages = counts.ToDictionary(
                    kvp => kvp.Key,
                    kvp => total == 0 ? 0d : (kvp.Value * 100d / total),
                    StringComparer.OrdinalIgnoreCase);

                summaries.Add(new QuestionSummaryRow
                {
                    TopSectionName = topSectionName,
                    SectionPath = sectionPath,
                    QuestionText = question.Text,
                    TotalResponses = total,
                    Counts = counts,
                    Percentages = percentages
                });
            }

            foreach (var subsection in section.Subsections)
            {
                Traverse(subsection, sectionPath, topSectionName);
            }
        }

        foreach (var root in roots)
        {
            Traverse(root, string.Empty, root.Name);
        }

        return summaries;
    }

    private static List<TopSectionSummaryGroup> BuildTopSectionGroups(List<QuestionSummaryRow> summaries)
    {
        return summaries
            .GroupBy(
                s => s.TopSectionName,
                StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
            .Select(g => new TopSectionSummaryGroup
            {
                TopSectionName = g.Key,
                QuestionSummaries = g
                    .OrderBy(x => x.SectionPath, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(x => x.QuestionText, StringComparer.OrdinalIgnoreCase)
                    .ToList()
            })
            .ToList();
    }

    private async Task ExportToCSV()
    {
        if (!questionSummaries.Any()) return;

        var csv = new StringBuilder();
        csv.AppendLine("Section,Question,Answer Option,Count,Percentage");

        foreach (var summary in questionSummaries)
        {
            foreach (var option in AnswerOptions)
            {
                var count = summary.Counts.GetValueOrDefault(option.Label, 0);
                var percentage = summary.Percentages.GetValueOrDefault(option.Label, 0d);
                csv.AppendLine($"\"{summary.SectionPath}\",\"{summary.QuestionText}\",\"{option.Label}\",{count},{percentage:0.00}");
            }
        }

        var bytes = Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"AuditResults_{DateTime.Now:yyyyMMdd_HHmmss}.csv";

        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64);
    }

    private static string FormatPercentForWidth(double percent)
    {
        return $"{percent.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}%";
    }

    private sealed class QuestionSummaryRow
    {
        public string TopSectionName { get; set; } = string.Empty;
        public string SectionPath { get; set; } = string.Empty;
        public string QuestionText { get; set; } = string.Empty;
        public int TotalResponses { get; set; }
        public Dictionary<string, int> Counts { get; set; } = new(StringComparer.OrdinalIgnoreCase);
        public Dictionary<string, double> Percentages { get; set; } = new(StringComparer.OrdinalIgnoreCase);
    }

    private sealed class TopSectionSummaryGroup
    {
        public string TopSectionName { get; set; } = string.Empty;
        public List<QuestionSummaryRow> QuestionSummaries { get; set; } = new();
    }

    private sealed class AnswerOptionColor
    {
        public AnswerOptionColor(string label, string color)
        {
            Label = label;
            Color = color;
        }

        public string Label { get; }
        public string Color { get; }
    }
}