    private UserRole GetPendingRole(int userId)
    {
        if (pendingUserRoles.TryGetValue(userId, out var role))
        {
            return role;
        }

        var user = users?.FirstOrDefault(u => u.Id == userId);
        return user?.Role ?? UserRole.Employee;
    }

    private void SetPendingRole(int userId, ChangeEventArgs e)
    {
        if (e.Value is null)
        {
            return;
        }

        if (!Enum.TryParse<UserRole>(e.Value.ToString(), out var parsedRole))
        {
            return;
        }

        pendingUserRoles[userId] = parsedRole;
    }

    private async Task ApplyUserRole(int userId)
    {
        if (!AuthStateService.IsAdmin) return;

        var targetUser = users?.FirstOrDefault(u => u.Id == userId);
        if (targetUser == null)
        {
            return;
        }

        if (!pendingUserRoles.TryGetValue(userId, out var parsedRole))
        {
            return;
        }

        var oldRole = targetUser.Role;
        if (oldRole == parsedRole)
        {
            userMessage = "No role change to apply.";
            userMessageIsError = false;
            return;
        }

        var updated = await AuthService.UpdateUserRoleAsync(userId, parsedRole);
        if (updated)
        {
            await LogActionAsync($"Updated user '{targetUser.Email}' role from '{oldRole}' to '{parsedRole}'");
            userMessage = $"Updated role for '{targetUser.Email}' to {parsedRole}.";
            userMessageIsError = false;
            await LoadUsers();
        }
        else
        {
            userMessage = "Failed to update role.";
            userMessageIsError = true;
        }
    }

    private bool CanApplyRole(int userId)
    {
        var targetUser = users?.FirstOrDefault(u => u.Id == userId);
        if (targetUser == null)
        {
            return false;
        }

        if (!pendingUserRoles.TryGetValue(userId, out var pendingRole))
        {
            pendingRole = targetUser.Role;
        }

        return targetUser.Role != pendingRole;
    }

    private string GetRoleBadgeStyle(UserRole role)
    {
        return role switch
        {
            UserRole.Admin => "background-color: #387c2b; color: white;",
            UserRole.Manager => "background-color: #ebbc4d; color: black;",
            UserRole.Employee => "background-color: #439539; color: white;",
            _ => "background-color: #5f6062; color: white;"
        };
    }

    private async Task LoadSurveyLocks()
    {
        activeTab = "locks";
        try
        {
            surveyLocks = await SurveyService.GetSurveyLockRowsAsync(lockFilter);
            if (surveyLocks.Count > 0)
            {
                expandedLockFacilities = surveyLocks
                    .Select(r => r.FacilityName)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
            }
            else
            {
                expandedLockFacilities.Clear();
            }
        }
        catch (Exception ex)
        {
            lockMessageIsError = true;
            lockMessage = $"Unable to load survey locks: {ex.Message}";
            surveyLocks = new List<SurveyLockRow>();
        }
    }

    private async Task ChangeLockFilter(string filter)
    {
        lockFilter = filter;
        await LoadSurveyLocks();
    }

    private void ToggleFacilityGroup(string facilityName)
    {
        if (!expandedLockFacilities.Add(facilityName))
        {
            expandedLockFacilities.Remove(facilityName);
        }
    }

    private void HandleLockToggleRequest(SurveyLockRow row, ChangeEventArgs e)
    {
        lockMessage = string.Empty;
        lockMessageIsError = false;

        var nextState = e.Value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var parsed) => parsed,
            _ => false
        };
        if (nextState == row.IsLocked)
        {
            return;
        }

        if (AuthStateService.IsManager && nextState)
        {
            lockMessageIsError = true;
            lockMessage = "Managers can only unlock surveys.";
            return;
        }

        pendingLockUserId = row.UserId;
        pendingLockCommunityKey = row.CommunityKey;
        pendingLockState = nextState;
        pendingLockUserName = row.UserDisplayName;
        pendingLockFacilityName = row.FacilityName;
        showLockConfirmDialog = true;
    }

    private void CancelLockChange()
    {
        showLockConfirmDialog = false;
        pendingLockUserId = null;
        pendingLockCommunityKey = null;
        pendingLockUserName = string.Empty;
        pendingLockFacilityName = string.Empty;
    }

    private async Task ConfirmLockChange()
    {
        if (pendingLockUserId == null || AuthStateService.CurrentUser == null)
        {
            CancelLockChange();
            return;
        }

        showLockConfirmDialog = false;
        isLockUpdateInProgress = true;
        lockMessage = string.Empty;
        lockMessageIsError = false;

        try
        {
            var changed = await SurveyService.SetSurveyLockStateAsync(
                pendingLockUserId.Value,
                pendingLockCommunityKey,
                pendingLockState,
                AuthStateService.CurrentUser.Id,
                AuthStateService.CurrentUser.Role);

            if (!changed)
            {
                lockMessage = "No lock state change was required.";
            }
            else
            {
                lockMessage = pendingLockState ? "Survey locked successfully." : "Survey unlocked successfully.";
                await LogActionAsync($"{(pendingLockState ? "Locked" : "Unlocked")} survey for user {pendingLockUserId.Value}, community {(pendingLockCommunityKey?.ToString() ?? "N/A")}");
            }
        }
        catch (UnauthorizedAccessException ex)
        {
            lockMessageIsError = true;
            lockMessage = ex.Message;
        }
        catch (Exception ex)
        {
            lockMessageIsError = true;
            lockMessage = $"Unable to apply lock state: {ex.Message}";
        }
        finally
        {
            CancelLockChange();
            isLockUpdateInProgress = false;
            await LoadSurveyLocks();
        }
    }

    private async Task LogActionAsync(string action)
    {
        var email = AuthStateService.CurrentUser?.Email ?? "Unknown";
        await LogService.LogAsync(action, email);
    }

    private async Task LoadLogs()
    {
        if (!AuthStateService.IsAdmin) return;

        activeTab = "logs";
        availableLogDates = LogService.GetAvailableLogDates();
        if (!availableLogDates.Contains(DateTime.Today))
        {
            availableLogDates.Insert(0, DateTime.Today);
        }

        // Ensure selected date is in the list or default to first
        if (!availableLogDates.Any(d => d.Date == selectedLogDate.Date))
        {
            selectedLogDate = availableLogDates.FirstOrDefault();
        }

        currentLogs = await LogService.GetLogsAsync(selectedLogDate);
    }

    private async Task OnLogDateChanged(ChangeEventArgs e)
    {
        if (!AuthStateService.IsAdmin) return;

        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            selectedLogDate = date;
            currentLogs = await LogService.GetLogsAsync(selectedLogDate);
        }
    }

    private string FindSectionName(int sectionId)
    {
        if (sections == null) return "Unknown";

        // Recursive search
        string Search(List<Section> list)
        {
            foreach (var s in list)
            {
                if (s.Id == sectionId) return s.Name;
                var found = Search(s.Subsections);
                if (found != "Unknown") return found;
            }
            return "Unknown";
        }

        return Search(sections);
    }

    private string FindQuestionText(int questionId)
    {
        if (sections == null) return "Unknown";

        string Search(List<Section> list)
        {
            foreach (var s in list)
            {
                var q = s.Questions.FirstOrDefault(q => q.Id == questionId);
                if (q != null) return q.Text;

                var found = Search(s.Subsections);
                if (found != "Unknown") return found;
            }
            return "Unknown";
        }

        return Search(sections);
    }
