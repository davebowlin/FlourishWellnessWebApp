@using FlourishWellness.Models
@using FlourishWellness.Services
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable

@page "/survey"
@inject SurveyService SurveyService
@inject AuthStateService AuthStateService
@inject NavigationManager NavigationManager
@inject LogService LogService
@inject IJSRuntime JSRuntime
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>FlourishWellness Survey</PageTitle>

<!-- Floating Progress Bar -->
<div style="position: fixed; top: 14px; right: 16px; width: 220px; padding: 8px 10px; background-color: #f6f9f7; border: 1px solid #d1d3d5; border-radius: 8px; z-index: 1001; box-shadow: 0 2px 8px rgba(0,0,0,0.14);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; color: #196887; font-size: 12px; font-weight: 600; font-family: 'Montserrat', Verdana, sans-serif;">
        <span>Progress</span>
        <span>@GetAnsweredQuestionCount() / @GetTotalQuestionCount()</span>
    </div>
    <div style="height: 8px; background-color: #8bb4c6; border-radius: 999px; overflow: hidden;">
        <div style="height: 100%; background-color: #196887; width: @(GetProgressPercentage())%; transition: width 0.3s ease-in-out;"></div>
    </div>
</div>

<div style="text-align: center; padding: 1rem 0 0.75rem; border-bottom: 2px solid var(--fw-primary-light); margin-bottom: 1.5rem;">
    <h2 style="margin: 0; font-family: 'Montserrat', Verdana, sans-serif; font-size: 1.5rem; font-weight: 600; color: var(--fw-primary); letter-spacing: 0.01em;">
        @(GetSelectedCommunityKey() == 0 ? "N/A" : (AuthStateService.SelectedFacility?.Facility ?? "N/A"))
        <span style="color: var(--fw-text); font-weight: 400;">&nbsp;&mdash;&nbsp;@(surveyYear?.Year.ToString() ?? "...")</span>
    </h2>
</div>

@if (sections is null)
{
    <p><em>Loading survey...</em></p>
}
else if (!sections.Any())
{
    <p><em>This area is not available to you right now.</em></p>
}
else
{
    @if (communityLocked)
    {
        <div style="padding: 20px; margin-bottom: 20px; background-color: #fffaec; border: 2px solid #ebbc4d; border-radius: 5px; color: #5f6062;">
            <h4 style="margin-top: 0;">Survey Year Archived</h4>
            <p style="margin: 0;">This survey year has been archived by an administrator. No further changes are permitted.</p>
        </div>
    }
    else if (submitted)
    {
        <div style="padding: 20px; margin-bottom: 20px; background-color: #d8e2b4; border: 1px solid #9fb456; border-radius: 5px; color: #387c2b;">
            <h4>Survey submitted and locked</h4>
            <p>This survey is locked for editing. A manager or admin must unlock it before any changes can be made.</p>
        </div>
    }

    @if (AuthStateService.RequiresFacilitySelection)
    {
        <div style="padding: 20px; margin-bottom: 20px; background-color: #fffaec; border: 2px solid #ebbc4d; border-radius: 5px; color: #5f6062; font-size: 18px; font-weight: 600;">
            Your account is assigned to multiple facilities. Please return to the home page and choose your facility before saving or submitting.
        </div>
    }

    @if (!string.IsNullOrEmpty(saveMessage))
    {
        <div style="position: fixed; top: 20px; right: 20px; padding: 15px; background-color: #d8e2b4; color: #387c2b; border-radius: 4px; box-shadow: 0 2px 5px rgba(0,0,0,0.2); z-index: 1000;">
            @saveMessage
        </div>
    }

    <div style="margin-bottom: 12px;">
        <button @onclick="ToggleAllSections"
                disabled="@(sections == null || !sections.Any())"
                style="padding: 8px 16px; background-color: #196887; color: white; border: none; border-radius: 4px; font-size: 14px; cursor: @((sections == null || !sections.Any()) ? "not-allowed" : "pointer"); opacity: @((sections == null || !sections.Any()) ? "0.7" : "1");">
            @(AreAllSectionsExpanded ? "Collapse All Sections" : "Expand All Sections")
        </button>
    </div>

    @foreach (var sec in sections!)
    {
        @RenderSectionSurvey(sec, 0)
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="padding: 10px; margin: 10px 0; background-color: #fffaec; color: #ff8c00; border-radius: 4px;">
            @errorMessage
        </div>
    }

    <button @onclick="OpenSubmitAndLockDialog" disabled="@(communityLocked || submitted || HasUnansweredQuestions())"
            style="padding: 12px 40px; background-color: @((communityLocked || submitted || HasUnansweredQuestions()) ? "#b0b0b0" : "#196887"); color: white; border: none; border-radius: 5px; font-size: 16px; cursor: @((communityLocked || submitted || HasUnansweredQuestions()) ? "not-allowed" : "pointer"); margin: 20px 0; font-weight: 500;">
        Submit and Lock
    </button>

    @if (showSubmitAndLockDialog)
    {
        <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 2000;">
            <div style="background: white; padding: 30px 36px; border-radius: 8px; max-width: 520px; width: 90%; box-shadow: 0 8px 32px rgba(0,0,0,0.25);">
                <h4 style="margin-top: 0; color: #196887;">Submit and Lock Survey</h4>
                <p style="color: #5f6062; margin-bottom: 24px;">
                    Submitting will lock this survey and prevent further edits. Only a manager or admin can unlock it.
                </p>
                <div style="display: flex; gap: 10px; justify-content: flex-end; flex-wrap: wrap;">
                    <button @onclick="ConfirmSubmitAndLock"
                            style="padding: 9px 18px; background-color: #196887; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                        Submit and Lock
                    </button>
                    <button @onclick="CancelSubmitAndLock"
                            style="padding: 9px 18px; background-color: #f6f9f7; color: #5f6062; border: 1px solid #d1d3d5; border-radius: 4px; cursor: pointer; font-size: 14px;">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showLeaveDialog)
    {
        <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 2000;">
            <div style="background: white; padding: 30px 36px; border-radius: 8px; max-width: 440px; width: 90%; box-shadow: 0 8px 32px rgba(0,0,0,0.25);">
                <h4 style="margin-top: 0; color: #196887;">Unsaved Changes</h4>
                <p style="color: #5f6062; margin-bottom: 24px;">You have unsaved changes. Would you like to save your progress before leaving?</p>
                <div style="display: flex; gap: 10px; justify-content: flex-end; flex-wrap: wrap;">
                    <button @onclick="LeaveDialogSaveAndLeave"
                            style="padding: 9px 18px; background-color: #387c2b; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                        Save &amp; Leave
                    </button>
                    <button @onclick="LeaveDialogLeaveWithoutSaving"
                            style="padding: 9px 18px; background-color: #5f6062; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                        Leave Without Saving
                    </button>
                    <button @onclick="LeaveDialogCancel"
                            style="padding: 9px 18px; background-color: #f6f9f7; color: #5f6062; border: 1px solid #d1d3d5; border-radius: 4px; cursor: pointer; font-size: 14px;">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<Section>? sections;
    private Dictionary<int, string> responses = new();
    private bool submitted = false;
    private bool communityLocked = false;
    private SurveyYear? surveyYear;
    private string errorMessage = string.Empty;
    private string saveMessage = string.Empty;
    private bool hasUnsavedChanges = false;
    private bool showLeaveDialog = false;
    private bool showSubmitAndLockDialog = false;
    private string pendingNavigationUrl = string.Empty;
    private HashSet<int> expandedSectionIds = new();
    private IDisposable? _locationChangingReg;
    private bool AreAllSectionsExpanded
    {
        get
        {
            if (sections == null || !sections.Any())
            {
                return false;
            }

            var allIds = GetAllSectionIds(sections);
            return allIds.Count > 0 && allIds.All(id => expandedSectionIds.Contains(id));
        }
    }

    private bool IsSurveyReadOnly => communityLocked || submitted;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthStateService.InitializeAsync();
            await AuthStateService.RefreshCurrentUserAsync();
            
            if (AuthStateService.CurrentUser != null)
            {
                surveyYear = await SurveyService.GetActiveSurveyYearAsync();
                communityLocked = await SurveyService.IsCommunitySurveyLockedAsync(GetSelectedCommunityKey());
                submitted = communityLocked || await SurveyService.IsSurveyCompletedAsync(AuthStateService.CurrentUser.Id, GetSelectedCommunityKey());
                await LogService.LogAsync("Started/Resumed survey", AuthStateService.CurrentUser.Email);
                await LoadSurvey();
            }
            else
            {
                NavigationManager.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            await LogService.LogAsync($"Error in Survey OnInitializedAsync: {ex.Message}", "System");
            Console.WriteLine($"Survey page error: {ex}");
        }
    }

    private async Task LoadSurvey()
    {
        try
        {
            sections = await SurveyService.GetSectionsAsync();
            expandedSectionIds.Clear();

            if (sections != null)
            {
                // Load existing responses
                if (AuthStateService.CurrentUser != null)
                {
                    var existingResponses = await SurveyService.GetUserResponsesAsync(AuthStateService.CurrentUser.Id, GetSelectedCommunityKey());
                    foreach (var kvp in existingResponses)
                    {
                        responses[kvp.Key] = kvp.Value;
                    }
                }

                foreach (var sec in sections)
                {
                    InitializeResponses(sec);
                }
            }
            else
            {
                sections = new List<Section>();
            }
        }
        catch (Exception ex)
        {
            await LogService.LogAsync($"Error loading survey: {ex.Message}", "System");
            sections = new List<Section>();
        }
    }

    private void InitializeResponses(Section sec)
    {
        foreach (var question in sec.Questions)
        {
            if (!responses.ContainsKey(question.Id))
            {
                responses[question.Id] = string.Empty;
            }
        }
        foreach (var subsec in sec.Subsections)
        {
            InitializeResponses(subsec);
        }
    }

    private static List<int> GetAllSectionIds(IEnumerable<Section> sectionList)
    {
        var ids = new List<int>();
        foreach (var sec in sectionList)
        {
            ids.Add(sec.Id);
            if (sec.Subsections.Any())
            {
                ids.AddRange(GetAllSectionIds(sec.Subsections));
            }
        }

        return ids;
    }

    private RenderFragment RenderSectionSurvey(Section sec, int level) => builder =>
    {
        var marginLeft = level * 20;
        var isExpanded = expandedSectionIds.Contains(sec.Id);
        var sectionQuestions = GetSectionQuestions(sec).ToList();
        var sectionTotalCount = sectionQuestions.Count;
        var sectionAnsweredCount = sectionQuestions.Count(q => responses.ContainsKey(q.Id) && !string.IsNullOrWhiteSpace(responses[q.Id]));
        var sectionProgressPercent = sectionTotalCount == 0 ? 0 : (sectionAnsweredCount * 100.0) / sectionTotalCount;

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "fw-accordion-panel");
        builder.AddAttribute(2, "style", $"margin-left: {marginLeft}px;");

        builder.OpenElement(3, "div");
        builder.AddAttribute(4, "class", "fw-accordion-header");
        builder.AddAttribute(5, "onclick", EventCallback.Factory.Create(this, () => ToggleSection(sec.Id)));
        builder.OpenElement(6, "h4");
        builder.AddAttribute(7, "class", "fw-accordion-title");
        builder.OpenElement(8, "span");
        builder.AddAttribute(9, "class", "fw-accordion-chevron");
        builder.AddContent(10, isExpanded ? "▼" : "▶");
        builder.CloseElement();
        builder.AddContent(11, sec.Name);
        builder.CloseElement();

        builder.OpenElement(12, "div");
        builder.AddAttribute(13, "style", "display: flex; align-items: center; gap: 8px; min-width: 180px;");

        builder.OpenElement(14, "span");
        builder.AddAttribute(15, "style", "font-size: 12px; font-weight: 600; color: #196887; white-space: nowrap;");
        builder.AddContent(16, $"{sectionAnsweredCount} / {sectionTotalCount}");
        builder.CloseElement();

        builder.OpenElement(17, "div");
        builder.AddAttribute(18, "style", "flex: 1; min-width: 90px; height: 7px; background-color: #8bb4c6; border-radius: 999px; overflow: hidden;");
        builder.OpenElement(19, "div");
        builder.AddAttribute(20, "style", $"height: 100%; background-color: #196887; width: {sectionProgressPercent:F1}%; transition: width 0.3s ease-in-out;");
        builder.CloseElement();
        builder.CloseElement();

        builder.CloseElement();
        builder.CloseElement();

        if (isExpanded && sec.Questions.Any())
        {
            builder.OpenElement(21, "table");
            builder.AddAttribute(22, "style", "width: 100%; border-collapse: collapse; background-color: white;");

            builder.OpenElement(23, "thead");
            builder.OpenElement(24, "tr");
            builder.AddAttribute(25, "style", "background-color: #196887; color: white;");

            builder.OpenElement(26, "th");
            builder.AddAttribute(27, "style", "padding: 12px; text-align: left; border: 1px solid #d1d3d5; width: 50%;");
            builder.AddContent(28, "Question");
            builder.CloseElement();

            builder.OpenElement(29, "th");
            builder.AddAttribute(30, "style", "padding: 12px; text-align: center; border: 1px solid #d1d3d5; width: 16.66%;");
            builder.AddContent(31, "Fully Implemented");
            builder.CloseElement();

            builder.OpenElement(32, "th");
            builder.AddAttribute(33, "style", "padding: 12px; text-align: center; border: 1px solid #d1d3d5; width: 16.66%;");
            builder.AddContent(34, "Partially Implemented");
            builder.CloseElement();

            builder.OpenElement(35, "th");
            builder.AddAttribute(36, "style", "padding: 12px; text-align: center; border: 1px solid #d1d3d5; width: 16.66%;");
            builder.AddContent(37, "Not a Current Practice");
            builder.CloseElement();

            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(38, "tbody");

            foreach (var question in sec.Questions)
            {
                var questionId = question.Id;
                builder.OpenElement(30, "tr");
                builder.AddAttribute(31, "style", "border-bottom: 1px solid #d1d3d5;");

                builder.OpenElement(32, "td");
                builder.AddAttribute(33, "style", "padding: 12px; border: 1px solid #d1d3d5; vertical-align: middle;");
                builder.OpenElement(34, "span");
                builder.AddAttribute(35, "style", "font-weight: 500; color: #5f6062;");
                builder.AddContent(36, question.Text);
                builder.CloseElement();
                builder.CloseElement();

                builder.OpenElement(37, "td");
                builder.AddAttribute(38, "style", "padding: 12px; border: 1px solid #d1d3d5; text-align: center; vertical-align: middle;");
                builder.OpenElement(39, "input");
                builder.AddAttribute(40, "type", "radio");
                builder.AddAttribute(41, "name", $"question_{questionId}");
                builder.AddAttribute(42, "value", "Fully Implemented");
                builder.AddAttribute(43, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => UpdateResponse(questionId, "Fully Implemented")));
                builder.AddAttribute(44, "checked", responses.GetValueOrDefault(questionId) == "Fully Implemented");
                builder.AddAttribute(45, "disabled", IsSurveyReadOnly);
                builder.AddAttribute(46, "style", "cursor: pointer; width: 18px; height: 18px;");
                builder.CloseElement();
                builder.CloseElement();

                builder.OpenElement(47, "td");
                builder.AddAttribute(48, "style", "padding: 12px; border: 1px solid #d1d3d5; text-align: center; vertical-align: middle;");
                builder.OpenElement(49, "input");
                builder.AddAttribute(50, "type", "radio");
                builder.AddAttribute(51, "name", $"question_{questionId}");
                builder.AddAttribute(52, "value", "Partially Implemented");
                builder.AddAttribute(53, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => UpdateResponse(questionId, "Partially Implemented")));
                builder.AddAttribute(54, "checked", responses.GetValueOrDefault(questionId) == "Partially Implemented");
                builder.AddAttribute(55, "disabled", IsSurveyReadOnly);
                builder.AddAttribute(56, "style", "cursor: pointer; width: 18px; height: 18px;");
                builder.CloseElement();
                builder.CloseElement();

                builder.OpenElement(57, "td");
                builder.AddAttribute(58, "style", "padding: 12px; border: 1px solid #d1d3d5; text-align: center; vertical-align: middle;");
                builder.OpenElement(59, "input");
                builder.AddAttribute(60, "type", "radio");
                builder.AddAttribute(61, "name", $"question_{questionId}");
                builder.AddAttribute(62, "value", "Not a Current Practice");
                builder.AddAttribute(63, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => UpdateResponse(questionId, "Not a Current Practice")));
                builder.AddAttribute(64, "checked", responses.GetValueOrDefault(questionId) == "Not a Current Practice");
                builder.AddAttribute(65, "disabled", IsSurveyReadOnly);
                builder.AddAttribute(66, "style", "cursor: pointer; width: 18px; height: 18px;");
                builder.CloseElement();
                builder.CloseElement();

                builder.CloseElement();
            }

            builder.CloseElement();
            builder.CloseElement();
        }

        if (isExpanded)
        {
            foreach (var subsec in sec.Subsections)
            {
                builder.AddContent(67, RenderSectionSurvey(subsec, level + 1));
            }

            // Section-level save button
            builder.OpenElement(68, "div");
            builder.AddAttribute(69, "style", "margin-top: 15px; text-align: right;");
            builder.OpenElement(70, "button");
            if (!IsSurveyReadOnly)
            {
                builder.AddAttribute(71, "onclick", EventCallback.Factory.Create(this, SaveProgress));
            }
            builder.AddAttribute(72, "disabled", IsSurveyReadOnly);
            builder.AddAttribute(73, "style", $"padding: 8px 16px; background-color: {(IsSurveyReadOnly ? "#b0b0b0" : "#5f6062")}; color: white; border: none; border-radius: 4px; cursor: {(IsSurveyReadOnly ? "not-allowed" : "pointer")};");
            builder.AddContent(74, "Save Progress");
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private void ToggleSection(int sectionId)
    {
        if (!expandedSectionIds.Add(sectionId))
        {
            expandedSectionIds.Remove(sectionId);
        }
    }

    private void ToggleAllSections()
    {
        if (sections == null || !sections.Any())
        {
            return;
        }

        var allSectionIds = GetAllSectionIds(sections);
        if (allSectionIds.Count == 0)
        {
            expandedSectionIds.Clear();
            return;
        }

        if (allSectionIds.All(id => expandedSectionIds.Contains(id)))
        {
            expandedSectionIds.Clear();
        }
        else
        {
            expandedSectionIds = allSectionIds.ToHashSet();
        }
    }

    private void UpdateResponse(int questionId, string value)
    {
        responses[questionId] = value;
        errorMessage = string.Empty; // Clear error on change
        saveMessage = string.Empty;
        if (!hasUnsavedChanges)
        {
            hasUnsavedChanges = true;
            _ = UpdateBeforeUnloadAsync(true);
        }
    }

    private async Task SaveProgress()
    {
        if (AuthStateService.CurrentUser == null) return;
        if (IsSurveyReadOnly) return;
        if (AuthStateService.RequiresFacilitySelection)
        {
            errorMessage = "Please select your facility first from the home page.";
            return;
        }

        try
        {
            await SurveyService.SaveUserResponsesAsync(
                AuthStateService.CurrentUser.Id,
                responses,
                AuthStateService.CurrentUser.SAMAccountName,
                AuthStateService.SelectedFacility?.CommunityKey);
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
            return;
        }
        hasUnsavedChanges = false;
        await UpdateBeforeUnloadAsync(false);
        saveMessage = "Progress saved successfully!";
        await LogService.LogAsync("Saved survey progress", AuthStateService.CurrentUser.Email);
        
        // Clear message after 3 seconds
        _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { saveMessage = string.Empty; StateHasChanged(); }));
    }

    private async Task SubmitSurvey()
    {
        if (AuthStateService.CurrentUser == null) return;
        if (IsSurveyReadOnly) return;
        if (AuthStateService.RequiresFacilitySelection)
        {
            errorMessage = "Please select your facility first from the home page.";
            return;
        }

        // Validate all questions answered
        var allQuestions = GetAllQuestions(sections);
        var unanswered = allQuestions.Where(q => !responses.ContainsKey(q.Id) || string.IsNullOrWhiteSpace(responses[q.Id])).ToList();

        if (unanswered.Any())
        {
            errorMessage = $"Please answer all questions before submitting. ({unanswered.Count} remaining)";
            return;
        }

        // Save final responses
        try
        {
            await SurveyService.SaveUserResponsesAsync(
                AuthStateService.CurrentUser.Id,
                responses,
                AuthStateService.CurrentUser.SAMAccountName,
                AuthStateService.SelectedFacility?.CommunityKey);
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
            return;
        }
        hasUnsavedChanges = false;
        await UpdateBeforeUnloadAsync(false);

        // Mark complete
        var completed = await SurveyService.CompleteSurveyAsync(AuthStateService.CurrentUser.Id, GetSelectedCommunityKey());
        if (!completed)
        {
            errorMessage = "Unable to submit until every question has a saved answer.";
            return;
        }

        submitted = true;
        await LogService.LogAsync("Submitted survey", AuthStateService.CurrentUser.Email);
    }

    private void OpenSubmitAndLockDialog()
    {
        if (IsSurveyReadOnly)
        {
            return;
        }

        showSubmitAndLockDialog = true;
    }

    private void CancelSubmitAndLock()
    {
        showSubmitAndLockDialog = false;
    }

    private async Task ConfirmSubmitAndLock()
    {
        showSubmitAndLockDialog = false;
        await SubmitSurvey();
    }

    private List<Question> GetAllQuestions(List<Section>? sections)
    {
        var questions = new List<Question>();
        if (sections == null) return questions;

        foreach (var sec in sections)
        {
            questions.AddRange(sec.Questions);
            questions.AddRange(GetAllQuestions(sec.Subsections));
        }
        return questions;
    }

    private static IEnumerable<Question> GetSectionQuestions(Section section)
    {
        foreach (var question in section.Questions)
        {
            yield return question;
        }

        foreach (var subsection in section.Subsections)
        {
            foreach (var question in GetSectionQuestions(subsection))
            {
                yield return question;
            }
        }
    }

    private void ResetSurvey()
    {
        // Resetting is not allowed per requirements once submitted. We can change this if needed in the future.
    }

    private bool HasUnansweredQuestions()
    {
        if (sections == null || !sections.Any())
        {
            return false;
        }

        var allQuestions = GetAllQuestions(sections);
        return allQuestions.Any(q => !responses.ContainsKey(q.Id) || string.IsNullOrWhiteSpace(responses[q.Id]));
    }

    private int GetTotalQuestionCount()
    {
        if (sections == null || !sections.Any())
        {
            return 0;
        }

        return GetAllQuestions(sections).Count;
    }

    private int GetAnsweredQuestionCount()
    {
        if (sections == null || !sections.Any())
        {
            return 0;
        }

        var allQuestions = GetAllQuestions(sections);
        return allQuestions.Count(q => responses.ContainsKey(q.Id) && !string.IsNullOrWhiteSpace(responses[q.Id]));
    }

    private double GetProgressPercentage()
    {
        var totalCount = GetTotalQuestionCount();
        if (totalCount == 0)
        {
            return 0;
        }

        var answeredCount = GetAnsweredQuestionCount();
        return (answeredCount * 100.0) / totalCount;
    }

    private int? GetSelectedCommunityKey()
    {
        var ck = AuthStateService.SelectedFacility?.CommunityKey;
        return int.TryParse(ck, out var val) ? val : 0;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _locationChangingReg = NavigationManager.RegisterLocationChangingHandler(OnLocationChanging);
        }
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!hasUnsavedChanges) return;

        // Prevent navigation immediately and show in-page dialog
        context.PreventNavigation();
        pendingNavigationUrl = context.TargetLocation;
        showLeaveDialog = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LeaveDialogSaveAndLeave()
    {
        showLeaveDialog = false;
        if (AuthStateService.CurrentUser != null && !AuthStateService.RequiresFacilitySelection && !IsSurveyReadOnly)
        {
            try
            {
                await SurveyService.SaveUserResponsesAsync(
                    AuthStateService.CurrentUser.Id,
                    responses,
                    AuthStateService.CurrentUser.SAMAccountName,
                    AuthStateService.SelectedFacility?.CommunityKey);
                await LogService.LogAsync("Saved survey progress before navigation", AuthStateService.CurrentUser.Email);
            }
            catch (InvalidOperationException)
            {
                // If the survey was locked in another session, continue navigation without blocking.
            }
        }
        hasUnsavedChanges = false;
        await UpdateBeforeUnloadAsync(false);
        NavigationManager.NavigateTo(pendingNavigationUrl);
    }

    private async Task LeaveDialogLeaveWithoutSaving()
    {
        showLeaveDialog = false;
        hasUnsavedChanges = false;
        await UpdateBeforeUnloadAsync(false);
        NavigationManager.NavigateTo(pendingNavigationUrl);
    }

    private void LeaveDialogCancel()
    {
        showLeaveDialog = false;
        pendingNavigationUrl = string.Empty;
    }

    private async Task UpdateBeforeUnloadAsync(bool enable)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync(enable ? "flourish.enableLeaveWarning" : "flourish.disableLeaveWarning");
        }
        catch { /* ignore JS interop errors during prerender or dispose */ }
    }

    public void Dispose()
    {
        _locationChangingReg?.Dispose();
        // Best-effort cleanup of the beforeunload handler when the component is torn down
        _ = UpdateBeforeUnloadAsync(false);
    }
}