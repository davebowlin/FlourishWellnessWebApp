@using FlourishWellness.Services
@using FlourishWellness.Models
@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject LogService LogService
@inject ADUserService ADUserService
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthStateService AuthStateService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="page">
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-header">
                <a href="/" class="nav-brand">
                    <img class="nav-logo" src="images/logo.svg" alt="Americareusa Senior Living" />
                </a>
                <button class="navbar-toggler" @onclick="ToggleNavMenu">
                    <span class="navbar-toggler-icon">☰</span>
                </button>
            </div>

            <div class="@NavMenuCssClass">
                <div class="nav-links">
                    @if (canViewDashboard)
                    {
                        <a href="/dashboard" class="nav-link">Dashboard</a>
                    }
                    @if (canAccessAdmin)
                    {
                        <a href="/admin" class="nav-link">Admin</a>
                    }
                    @if (canViewResults)
                    {
                        <a href="/results" class="nav-link">View Results</a>
                    }
                    @if (!AuthStateService.RequiresFacilitySelection)
                    {
                        <a href="/survey" class="nav-link">Take Survey</a>
                    }
                </div>

                <div class="nav-user">
                    @if (AuthStateService.IsAuthenticated && AuthStateService.ADFacilities.Count > 0)
                    {
                        @if (AuthStateService.ADFacilities.Count == 1)
                        {
                            <span class="facility-chip">Facility: @AuthStateService.ADFacilities[0].Facility</span>
                        }
                        else
                        {
                            <div class="facility-switcher">
                                <label for="facility-select">Facility:</label>
                                <select id="facility-select" value="@selectedFacilityValue" @onchange="HandleFacilitySelectionChanged">
                                    @foreach (var facility in AuthStateService.ADFacilities)
                                    {
                                        <option value="@BuildFacilityOptionValue(facility)">
                                            @facility.Facility (@(string.IsNullOrWhiteSpace(facility.CommunityKey) ? "N/A" : facility.CommunityKey))
                                        </option>
                                    }
                                </select>
                            </div>
                        }
                    }
                    <span class="user-email">@displayUserName</span>
                    @if (showDefaultAdminLogout)
                    {
                        <button class="btn-logout" @onclick="LogoutAsync">LOGOUT</button>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main>
        @Body
    </main>

    <footer>
        <p>&copy; Americare Senior Living</p>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool collapseNavMenu = true;
    private string displayUserName = "Guest User";
    private bool canViewDashboard;
    private bool canAccessAdmin;
    private bool canViewResults;
    private bool showDefaultAdminLogout;
    private string selectedFacilityValue = string.Empty;
    private string? NavMenuCssClass => collapseNavMenu ? "nav-menu collapse" : "nav-menu";

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        AuthStateService.OnAuthStateChanged += HandleAuthStateChanged;

        try
        {
            await AuthStateService.InitializeAsync();
            await AuthStateService.RefreshCurrentUserAsync();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            await UpdateDisplayStateAsync(authState.User);
        }
        catch (Exception ex)
        {
            // Fallback so the page still loads
            displayUserName = "User Error";
            Console.WriteLine($"Auth Error: {ex.Message}");
        }
    }

    private async Task UpdateDisplayStateAsync(System.Security.Claims.ClaimsPrincipal user)
    {
        var currentUser = AuthStateService.CurrentUser;

        if (currentUser != null)
        {
            displayUserName = !string.IsNullOrWhiteSpace(currentUser.FullName)
                ? currentUser.FullName
                : currentUser.Email;
            canViewDashboard = currentUser.Role != UserRole.Employee;
            canAccessAdmin = currentUser.Role == UserRole.Admin;
            canViewResults = currentUser.Role == UserRole.Admin || currentUser.Role == UserRole.Manager;
            showDefaultAdminLogout = string.Equals(currentUser.Email, "admin", StringComparison.OrdinalIgnoreCase);
            selectedFacilityValue = BuildFacilityOptionValue(AuthStateService.SelectedFacility);
            return;
        }

        if (user.Identity?.IsAuthenticated == true)
        {
            var fullName = ADUserService.GetFullName(user);
            displayUserName = !string.IsNullOrWhiteSpace(fullName)
                ? fullName
                : (user.Identity.Name ?? "Authenticated User");
        }
        else
        {
            displayUserName = "Guest User";
        }

        canViewDashboard = false;
        canAccessAdmin = false;
        canViewResults = false;
        showDefaultAdminLogout = false;
        selectedFacilityValue = string.Empty;
    }

    private static string BuildFacilityOptionValue(ADFacilityUser? facility)
    {
        if (facility == null)
        {
            return string.Empty;
        }

        return $"{facility.Facility}|{facility.CommunityKey ?? string.Empty}";
    }

    private async Task HandleFacilitySelectionChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
        {
            return;
        }

        var parts = raw.Split('|', 2);
        if (parts.Length != 2)
        {
            return;
        }

        var facility = parts[0];
        var communityKey = parts[1];
        var currentValue = BuildFacilityOptionValue(AuthStateService.SelectedFacility);
        if (string.Equals(raw, currentValue, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var onSurveyPage = currentPath.StartsWith("survey", StringComparison.OrdinalIgnoreCase);

        if (onSurveyPage)
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
                "Switching facility will reload the survey context. Continue?");
            if (!confirmed)
            {
                selectedFacilityValue = currentValue;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        await AuthStateService.SetSelectedFacilityAsync(facility, string.IsNullOrWhiteSpace(communityKey) ? null : communityKey);
        selectedFacilityValue = BuildFacilityOptionValue(AuthStateService.SelectedFacility);

        if (onSurveyPage)
        {
            NavigationManager.NavigateTo("/survey", forceLoad: true);
        }
    }

    private async Task LogoutAsync()
    {
        await AuthStateService.LogoutAsync();
        NavigationManager.NavigateTo("/admin-login", forceLoad: false);
    }

    private async void HandleAuthStateChanged()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            await UpdateDisplayStateAsync(authState.User);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // no-op
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        collapseNavMenu = true;
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
        AuthStateService.OnAuthStateChanged -= HandleAuthStateChanged;
    }
}